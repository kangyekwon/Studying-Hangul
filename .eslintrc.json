{
  "env": {
    "browser": true,
    "es2021": true,
    "jest": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-script-url": "error",
    "no-unused-vars": "warn",
    "no-console": "off",
    "prefer-const": "warn",
    "no-var": "warn"
  },
  "globals": {
    "gameState": "writable",
    "vocabularyData": "readonly",
    "speakKorean": "readonly",
    "escapeHtml": "readonly",
    "saveProgress": "writable",
    "loadProgress": "writable"
  }
}
